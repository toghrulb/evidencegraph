# Compose project
COMPOSE_PROJECT_NAME=evidencegraph

# PostgreSQL with pgvector
POSTGRES_DB=evidencegraph
POSTGRES_USER=evidencegraph
POSTGRES_PASSWORD=evidencegraph_local_only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://evidencegraph:evidencegraph_local_only@localhost:5432/evidencegraph

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MinIO / S3-compatible object storage
MINIO_CONSOLE_PORT=9001
S3_PORT=9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=evidencegraph
S3_SECRET_KEY=evidencegraph_local_only
S3_BUCKET=evidencegraph-papers

# Phase 1 upload limit and Phase 2 processing limits
MAX_UPLOAD_MB=50
MAX_PDF_PAGES=500

# Phase 2 deterministic parsing and chunking
DEFAULT_CHUNKING_STRATEGY=section_aware
FIXED_CHUNK_SIZE=512
FIXED_CHUNK_OVERLAP=64
MINIMUM_CHUNK_SIZE=64
TOKENIZER_NAME=unicode_lexical_v1
PARSER_VERSION=pymupdf-v1
CHUNKING_CONFIG_VERSION=v1

# Local ML defaults (consumed in later phases)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=
DEFAULT_DENSE_TOP_K=20
DEFAULT_SPARSE_TOP_K=20
DEFAULT_RERANK_TOP_K=8
RRF_K=60

# Application ports and browser-visible API URL
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
